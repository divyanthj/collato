# -----------------------------------------------------------------------------
# App + Auth.js
# -----------------------------------------------------------------------------
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Resend / email sign-in
# Verify the sending domain `resend.collato.io` in Resend, then use a sender
# like `Collato.io <hello@resend.collato.io>`.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
AUTH_RESEND_FROM="Collato.io <hello@resend.collato.io>"
RESEND_REPLY_TO="support@collato.io"
CRON_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
